@model IEnumerable<Car_Rent_System.Models.OwnDrivers>

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"] - OwnDrivers Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

</head>
<body>
    <div class="mt-5 pt-md-5 ">
        <nav class="navbar navbar-expand-lg navbar-light bg-light sticky-top shadow">

            <div class="container-fluid">
                <!-- Sidebar / Dropdown Trigger -->
                <div class="dropdown">
                    <a class="navbar-brand dropdown-toggle" href="#" role="button" id="dropdownMenuLink"
                       data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-list fs-3"></i>
                    </a>

                    <ul class="dropdown-menu" aria-labelledby="dropdownMenuLink">
                        <li><a class="dropdown-item" href="#earnings-section">🏠 Home</a></li>
                        <li><a class="dropdown-item" href="/OwnDrivers/Profile">👤 Profile</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="/Account/Logout">🚪 Logout</a></li>
                    </ul>

                </div>

                <form class="d-flex">
                    <i class="bi bi-bell"></i>
                    <span class="position-absolute start-100 translate-middle badge rounded-pill bg-pink text-white" style="background-color: #d63384;">

                    </span>
                </form>

            </div>
        </nav>


        <div>
            <p>Ready to start earning today?</p>
        </div>


        <div class="row ps-md-4">
            <div class="col-md-4 rounded-3">
                <div class="card p-3 mb-3 bg-dark text-white  ">
                    <h5 class="text-warning">Today’s Earnings</h5>
                    <i class="fas fa-dollar-sign text-secondary"></i>
                </div>

            </div>

            <div class="col-md-3 rounded">
                <div class="card p-3 mb-3 bg-dark text-white">
                    <h5 class="text-warning">Weekly Earnings</h5>
                    <i class="fas fa-dollar-sign text-secondary"></i>
                </div>
            </div>

            <div class="col-md-3 rounded">
                <div class="card p-3 mb-3 bg-dark text-white">
                    <h5 class="text-warning">Monthly Earnings</h5>
                    <i class="fas fa-dollar-sign text-secondary"></i>
                </div>
            </div>

            <div class="col-md-3 rounded">
                <div class="card p-3 mb-3 bg-dark text-white">
                    <h5 class="text-warning">Pending Payments</h5>
                    <i class="fas fa-dollar-sign text-secondary"></i>
                </div>
            </div>
        </div>



        <div class="row ps-md-4">
            <!-- Current Trip Card -->
            <div class="col-lg-6">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <!-- Header -->
                        <div class="d-flex align-items-center mb-3">
                            <i class="fas fa-car text-primary me-2"></i>
                            <h5 class="mb-0">Current Trip</h5>
                        </div>

                        <!-- Status & Time -->
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <span class="badge bg-success bg-opacity-25 text-success fw-semibold px-3 py-1">
                                In Progress
                            </span>
                            <div class="text-muted small d-flex align-items-center">
                                <i class="far fa-clock me-1"></i>
                                12 min remaining
                            </div>
                        </div>

                        <!-- Pickup & Drop-off -->
                        <div class="mb-4">
                            <!-- Pickup -->
                            <div class="d-flex align-items-start mb-3">
                                <div class="bg-primary rounded-circle mt-1 me-3" style="width: 10px; height: 10px;"></div>
                                <div>
                                    <p class="mb-0 fw-semibold">Pickup Location</p>
                                    <p class="mb-0 text-muted small"></p>
                                </div>
                            </div>

                            <!-- Dashed line -->
                            <div class="border-start border-2 border-dashed ms-2 mb-3" style="height: 20px;"></div>

                            <!-- Drop-off -->
                            <div class="d-flex align-items-start">
                                <i class="fas fa-map-marker-alt text-secondary mt-1 me-3"></i>
                                <div>
                                    <p class="mb-0 fw-semibold">Drop-off Location</p>
                                    <p class="mb-0 text-muted small"></p>
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-flex gap-2 pt-2 flex-wrap">
                            <a href="#" class="btn btn-primary btn-sm flex-fill">
                                <i class="fas fa-location-arrow me-2"></i> Navigate
                            </a>
                            <button class="btn btn-outline-secondary btn-sm">
                                <i class="fas fa-phone-alt me-2"></i> Call
                            </button>
                            <button class="btn btn-outline-secondary btn-sm">
                                <i class="fas fa-comment-alt me-2"></i> Message
                            </button>
                        </div>
                    </div>
                </div>
            </div>


            <div class="card shadow-sm mb-4  col-lg-6">
                <div class="card-header d-flex align-items-center  col-lg-6">
                    <i class="fas fa-star text-primary me-2"></i>
                    <h5 class="mb-0">Recent Reviews</h5>
                </div>
                <div class="col-lg-6">
                    <!-- Review 1 -->
                    <div class="d-flex align-items-start gap-3 p-3 bg-light rounded mb-3">
                        <div class="avatar bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            SM
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center mb-1 gap-2">
                                <strong class="small mb-0">Sarah M.</strong>
                                <div class="text-warning">
                                    <i class="fas fa-star small"></i>
                                    <i class="fas fa-star small"></i>
                                    <i class="fas fa-star small"></i>
                                    <i class="fas fa-star small"></i>
                                    <i class="fas fa-star small"></i>
                                </div>
                            </div>
                            <p class="text-muted small mb-0">"Great driver! Very professional and arrived on time."</p>
                        </div>
                    </div>

                    <!-- Review 2 -->
                    <div class="d-flex align-items-start gap-3 p-3 bg-light rounded mb-3">
                        <div class="avatar bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            MJ
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center mb-1 gap-2">
                                <strong class="small mb-0">Mike J.</strong>
                                <div class="text-warning">
                                    <i class="fas fa-star small"></i>
                                    <i class="fas fa-star small"></i>
                                    <i class="fas fa-star small"></i>
                                    <i class="fas fa-star small"></i>
                                    <i class="fas fa-star small"></i>
                                </div>
                            </div>
                            <p class="text-muted small mb-0">"Smooth ride and friendly conversation. Highly recommend!"</p>
                        </div>
                    </div>

                    <!-- Review 3 -->
                    <div class="d-flex align-items-start gap-3 p-3 bg-light rounded">
                        <div class="avatar bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            AL
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center mb-1 gap-2">
                                <strong class="small mb-0">Anna L.</strong>
                                <div class="text-warning">
                                    <i class="fas fa-star small"></i>
                                    <i class="fas fa-star small"></i>
                                    <i class="fas fa-star small"></i>
                                    <i class="fas fa-star small"></i>
                                    <i class="far fa-star small text-secondary"></i> <!-- empty star -->
                                </div>
                            </div>
                            <p class="text-muted small mb-0">"Good service, clean car. Could improve on navigation."</p>
                        </div>
                    </div>
                </div>
            </div>

        </div>


        <div class="card shadow-sm h-50 ps-md-4">

            <h5 class="card-title mb-4 p-1">Today's Stats</h5>
            <div class="row text-center">
                <!-- Trips Completed -->
                <div class="col-md-3 col-6 mb-3">
                    <div class="text-primary fw-bold fs-3">8</div>
                    <div class="text-muted small">Trips Completed</div>
                </div>

                <!-- Hours Online -->
                <div class="col-md-3 col-6 mb-3">
                    <div class="text-primary fw-bold fs-3">6.2</div>
                    <div class="text-muted small">Hours Online</div>
                </div>

                <!-- Miles Driven -->
                <div class="col-md-3 col-6 mb-3">
                    <div class="text-primary fw-bold fs-3">47</div>
                    <div class="text-muted small">Miles Driven</div>
                </div>

                <!-- Avg Rating -->
                <div class="col-md-3 col-6 mb-3">
                    <div class="text-primary fw-bold fs-3">4.9</div>
                    <div class="text-muted small">Avg Rating</div>
                </div>
            </div>


        </div>

    </div>
</body>
</html>










