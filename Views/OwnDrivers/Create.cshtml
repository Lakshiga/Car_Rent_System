@{
    ViewData["Title"] = "Own Divers Register";

}



@model Car_Rent_System.Models.OwnDrivers
<h2>Create Driver</h2>

<form asp-action="Create" method="post" class="driver-form">
    <div class="form-group">
        <label asp-for="Fname"></label>
        <input asp-for="Fname" class="form-control" placeholder="Enter First Name" />
        <span asp-validation-for="Fname" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Lname"></label>
        <input asp-for="Lname" class="form-control" placeholder="Enter Last Name" />
        <span asp-validation-for="Lname" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Address"></label>
        <input asp-for="Address" class="form-control" placeholder="Enter Address" />
        <span asp-validation-for="Address" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Experience"></label>
        <input asp-for="Experience" type="number" class="form-control" placeholder="Years of Experience" />
        <span asp-validation-for="Experience" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="NIC"></label>
        <input asp-for="NIC" class="form-control" placeholder="Enter NIC Number" />
        <span asp-validation-for="NIC" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="DriversLicense_No"></label>
        <input asp-for="DriversLicense_No" class="form-control" placeholder="Enter Driver’s License Number" />
        <span asp-validation-for="DriversLicense_No" class="text-danger"></span>
    </div>

    <div class="form-actions mt-3">
        <input type="submit" value="Create" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}