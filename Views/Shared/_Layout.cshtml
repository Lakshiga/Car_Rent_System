<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Navbar scroll effect with enhanced animation
        let lastScrollTop = 0;
        window.addEventListener('scroll', function() {
            let scrollTop = window.scrollY || document.documentElement.scrollTop;
            if (scrollTop > 50) {
                document.getElementById('mainNavbar').classList.add('scrolled');
            } else {
                document.getElementById('mainNavbar').classList.remove('scrolled');
            }
            // Direction aware navbar
            if (scrollTop > lastScrollTop && scrollTop > 100) {
                // Scrolling down
                document.getElementById('mainNavbar').style.transform = 'translateY(-100%)';
            } else {
                // Scrolling up
                document.getElementById('mainNavbar').style.transform = 'translateY(0)';
            }
            lastScrollTop = scrollTop;
        });
        // Auto-hide alerts
        setTimeout(function() {
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(alert => {
                alert.classList.add('fade');
                setTimeout(() => {
                    alert.style.display = 'none';
                }, 500);
            });
        }, 5000);
        // Enhanced form submission with loading animation
        const forms = document.querySelectorAll('form');
        forms.forEach(form => {
            form.addEventListener('submit', function(e) {
                const submitBtn = form.querySelector('button[type="submit"]');
                if (submitBtn) {
                    const originalText = submitBtn.innerHTML;
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<span class="loading-spinner"></span> Processing...';
                    submitBtn.classList.add('btn-cynex-secondary');
                    // Reset button after 3 seconds (in case of no response)
                    setTimeout(function() {
                        if (submitBtn) {
                            submitBtn.disabled = false;
                            submitBtn.innerHTML = originalText;
                            submitBtn.classList.remove('btn-cynex-secondary');
                        }
                    }, 3000);
                }
            });
        });
        // Animation on scroll with Intersection Observer for better performance
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, observerOptions);
        // Observe all animated elements
        document.querySelectorAll('.animate-fade-in, .animate-slide-in, .animate-scale-in').forEach(el => {
            observer.observe(el);
        });
        // Calculate total cost dynamically
        function calculateTotalCost() {
            const pickupDateInput = document.getElementById('PickupDate');
            const returnDateInput = document.getElementById('ReturnDate');
            const dailyRateInput = document.getElementById('DailyRate');
            const totalDaysElement = document.getElementById('TotalDays');
            const totalCostElement = document.getElementById('TotalCost');
            if (!pickupDateInput || !returnDateInput || !dailyRateInput) return;
            const pickupDate = new Date(pickupDateInput.value);
            const returnDate = new Date(returnDateInput.value);
            const dailyRate = parseFloat(dailyRateInput.value) || 0;
            if (pickupDate && returnDate && returnDate > pickupDate) {
                const timeDiff = returnDate.getTime() - pickupDate.getTime();
                const daysDiff = Math.ceil(timeDiff / (1000 * 3600 * 24)) + 1;
                const totalCost = daysDiff * dailyRate;
                if (totalDaysElement) {
                    totalDaysElement.textContent = daysDiff + ' day' + (daysDiff > 1 ? 's' : '');
                }
                if (totalCostElement) {
                    totalCostElement.textContent = '$' + totalCost.toFixed(2);
                }
            }
        }
        // Attach event listeners for date inputs
        const dateInputs = document.querySelectorAll('#PickupDate, #ReturnDate');
        dateInputs.forEach(input => {
            input.addEventListener('change', calculateTotalCost);
        });
        // Enhanced form validation with real-time feedback
        const formElements = document.querySelectorAll('input, select, textarea');
        formElements.forEach(element => {
            element.addEventListener('blur', function() {
                validateField(this);
            });
            element.addEventListener('input', function() {
                if (this.classList.contains('is-invalid')) {
                    validateField(this);
                }
            });
        });
        function validateField(field) {
            if (field.validity && !field.validity.valid) {
                field.classList.add('is-invalid');
                field.classList.remove('is-valid');
            } else {
                field.classList.remove('is-invalid');
                field.classList.add('is-valid');
            }
        }
        // Add floating animation to selected elements
        const floatingElements = document.querySelectorAll('.stats-card, .car-card');
        floatingElements.forEach(el => {
            el.classList.add('floating');
        });
        // Add hover glow effect to buttons and cards
        const glowElements = document.querySelectorAll('.btn-cynex-primary, .btn-cynex-secondary, .cynex-card');
        glowElements.forEach(el => {
            el.classList.add('glow-hover');
        });
        // Parallax effect for hero section
        window.addEventListener('mousemove', function(e) {
            const heroSection = document.querySelector('.hero-section');
            if (heroSection) {
                const xAxis = (window.innerWidth / 2 - e.pageX) / 25;
                const yAxis = (window.innerHeight / 2 - e.pageY) / 25;
                heroSection.style.transform = `translateX(${xAxis}px) translateY(${yAxis}px) scale(1.05)`;
            }
        });
        // Add subtle pulsing animation to price tags
        const priceTags = document.querySelectorAll('.price-tag');
        priceTags.forEach(tag => {
            setInterval(() => {
                tag.style.transform = 'scale(1.05)';
                setTimeout(() => {

                    tag.style.transform = 'scale(1)';
                }, 500);
            }, 3000);
        });
    });
</script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
