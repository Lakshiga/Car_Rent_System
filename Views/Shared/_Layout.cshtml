<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CYNEX BLAZER Car Rental</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --cynex-black: #000000;
            --cynex-silver: #C0C0C0;
            --cynex-blue: #0A2472;
            --cynex-gold: #D4AF37;
            --cynex-neon-blue: #00B4FF;
            --cynex-dark-silver: #808080;
            --cynex-light-silver: #E8E8E8;
            --cynex-gradient: linear-gradient(135deg, #000000 0%, #1a1a1a 50%, #000000 100%);
            --cynex-blue-gradient: linear-gradient(45deg, #0A2472, #0D3B9E);
            --cynex-gold-gradient: linear-gradient(45deg, #D4AF37, #F9E076);
            --cynex-neon-gradient: linear-gradient(45deg, #00B4FF, #0066FF);
            --cynex-silver-gradient: linear-gradient(45deg, #C0C0C0, #E8E8E8);
            --cynex-purple: #6A0DAD;
            --cynex-red: #C8102E;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Rajdhani', sans-serif;
            background: var(--cynex-black);
            color: var(--cynex-silver);
            line-height: 1.6;
            overflow-x: hidden;
            position: relative;
        }

            /* Animated Background */
            body::before {
                content: '';
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: radial-gradient(circle at 20% 80%, rgba(10, 36, 114, 0.15) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(212, 175, 55, 0.08) 0%, transparent 50%), radial-gradient(circle at 50% 50%, rgba(0, 180, 255, 0.05) 0%, transparent 70%), var(--cynex-black);
                z-index: -2;
            }

            /* Floating Particles */
            body::after {
                content: '';
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background-image: radial-gradient(circle, rgba(212, 175, 55, 0.4) 1px, transparent 1px), radial-gradient(circle, rgba(0, 180, 255, 0.3) 1px, transparent 1px), radial-gradient(circle, rgba(192, 192, 192, 0.2) 1px, transparent 1px);
                background-size: 50px 50px, 70px 70px, 90px 90px;
                background-position: 0 0, 25px 25px, 50px 50px;
                opacity: 0.3;
                animation: float 20s linear infinite;
                z-index: -1;
            }

        @@keyframes float {
            0% {
                background-position: 0 0, 25px 25px, 50px 50px;
            }

            100% {
                background-position: 100px 100px, 125px 125px, 150px 150px;
            }
        }

        .cynex-font {
            font-family: 'Orbitron', monospace;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 3px;
            position: relative;
        }

            .cynex-font::after {
                content: '';
                position: absolute;
                bottom: -5px;
                left: 0;
                width: 0;
                height: 2px;
                background: var(--cynex-gold-gradient);
                transition: width 0.5s ease;
            }

            .cynex-font:hover::after {
                width: 100%;
            }

        .text-cynex-silver {
            color: var(--cynex-silver) !important;
        }

        .text-cynex-blue {
            color: var(--cynex-blue) !important;
        }

        .text-cynex-gold {
            color: var(--cynex-gold) !important;
        }

        .text-cynex-neon {
            color: var(--cynex-neon-blue) !important;
        }

        /* Enhanced Navbar */
        .navbar {
            background: rgba(0, 0, 0, 0.92) !important;
            backdrop-filter: blur(15px);
            border-bottom: 2px solid transparent;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
            padding: 1rem 0;
            transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
        }

            .navbar.scrolled {
                background: rgba(0, 0, 0, 0.98) !important;
                box-shadow: 0 8px 40px rgba(10, 36, 114, 0.6);
                border-bottom: 2px solid var(--cynex-gold);
                transform: translateY(0);
            }

        .navbar-brand {
            display: flex;
            align-items: center;
            font-family: 'Orbitron', monospace;
            font-weight: 900;
            font-size: 1.8rem;
            color: var(--cynex-gold) !important;
            text-decoration: none;
            transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            position: relative;
        }

            .navbar-brand::before {
                content: '';
                position: absolute;
                bottom: -5px;
                left: 0;
                width: 100%;
                height: 3px;
                background: var(--cynex-gold-gradient);
                transform: scaleX(0);
                transform-origin: left;
                transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            }

            .navbar-brand:hover {
                color: var(--cynex-neon-blue) !important;
                transform: scale(1.08) rotate(2deg);
            }

                .navbar-brand:hover::before {
                    transform: scaleX(1);
                }

            .navbar-brand img {
                height: 55px;
                width: auto;
                margin-right: 15px;
                filter: drop-shadow(0 0 15px rgba(212, 175, 55, 0.7));
                transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
                transform: rotate(0);
            }

            .navbar-brand:hover img {
                filter: drop-shadow(0 0 25px rgba(212, 175, 55, 1));
                transform: rotate(10deg);
            }

        .navbar .nav-link {
            color: var(--cynex-silver) !important;
            font-weight: 600;
            font-size: 1.1rem;
            margin: 0 8px;
            padding: 12px 25px !important;
            border-radius: 30px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            border: 1px solid transparent;
        }

            .navbar .nav-link::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: var(--cynex-gold-gradient);
                transition: all 0.4s ease;
                z-index: -1;
            }

            .navbar .nav-link:hover {
                color: var(--cynex-black) !important;
                transform: translateY(-3px) scale(1.05);
                border: 1px solid var(--cynex-gold);
                box-shadow: 0 8px 25px rgba(212, 175, 55, 0.4);
            }

                .navbar .nav-link:hover::before {
                    left: 0;
                }

            .navbar .nav-link i {
                margin-right: 8px;
                transition: transform 0.3s ease;
            }

            .navbar .nav-link:hover i {
                transform: rotate(15deg);
            }

        /* Premium Buttons */
        .btn-cynex-primary {
            background: var(--cynex-gold-gradient);
            border: none;
            color: var(--cynex-black);
            font-weight: 700;
            padding: 15px 40px;
            border-radius: 50px;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            box-shadow: 0 8px 25px rgba(212, 175, 55, 0.4);
            position: relative;
            overflow: hidden;
            font-family: 'Orbitron', monospace;
            font-size: 1.1rem;
        }

            .btn-cynex-primary::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(45deg, #F9E076, #D4AF37);
                transition: all 0.4s ease;
                z-index: -1;
            }

            .btn-cynex-primary:hover {
                transform: translateY(-5px) scale(1.05);
                box-shadow: 0 15px 35px rgba(212, 175, 55, 0.6);
                color: var(--cynex-black);
                letter-spacing: 3px;
            }

                .btn-cynex-primary:hover::before {
                    left: 0;
                }

            .btn-cynex-primary::after {
                content: '';
                position: absolute;
                width: 150%;
                height: 150%;
                background: radial-gradient(circle, rgba(255,255,255,0.3) 0%, rgba(255,255,255,0) 70%);
                top: -25%;
                left: -25%;
                opacity: 0;
                transition: opacity 0.4s;
            }

            .btn-cynex-primary:hover::after {
                opacity: 1;
            }

        .btn-cynex-secondary {
            background: transparent;
            border: 2px solid var(--cynex-gold);
            color: var(--cynex-gold);
            font-weight: 700;
            padding: 15px 40px;
            border-radius: 50px;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            position: relative;
            overflow: hidden;
            font-family: 'Orbitron', monospace;
            font-size: 1.1rem;
            box-shadow: 0 5px 20px rgba(212, 175, 55, 0.2);
        }

            .btn-cynex-secondary::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: var(--cynex-gold-gradient);
                transition: all 0.4s ease;
                z-index: -1;
            }

            .btn-cynex-secondary:hover {
                color: var(--cynex-black);
                transform: translateY(-5px) scale(1.05);
                box-shadow: 0 15px 35px rgba(212, 175, 55, 0.4);
                letter-spacing: 3px;
            }

                .btn-cynex-secondary:hover::before {
                    left: 0;
                }

        /* Premium Cards */
        .cynex-card {
            background: rgba(10, 15, 30, 0.8);
            border: 1px solid rgba(212, 175, 55, 0.2);
            border-radius: 25px;
            backdrop-filter: blur(15px);
            transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }

            .cynex-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 4px;
                background: var(--cynex-gold-gradient);
                transform: scaleX(0);
                transition: transform 0.5s ease;
            }

            .cynex-card::after {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: linear-gradient(135deg, rgba(212, 175, 55, 0.05) 0%, transparent 100%);
                opacity: 0;
                transition: opacity 0.5s ease;
                z-index: -1;
            }

            .cynex-card:hover {
                transform: translateY(-15px) scale(1.02);
                border-color: var(--cynex-gold);
                box-shadow: 0 25px 50px rgba(212, 175, 55, 0.3);
            }

                .cynex-card:hover::before {
                    transform: scaleX(1);
                }

                .cynex-card:hover::after {
                    opacity: 1;
                }

        /* Hero Section */
        .hero-section {
            background: linear-gradient(135deg, rgba(10, 20, 40, 0.9) 0%, rgba(5, 10, 25, 0.95) 100%), url('https://images.unsplash.com/photo-1580273916550-e323be2ae537?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1740&q=80');
            background-size: cover;
            background-position: center;
            min-height: 100vh;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden;
            padding: 100px 0;
        }

            .hero-section::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: radial-gradient(circle at 30% 70%, rgba(212, 175, 55, 0.1) 0%, transparent 50%);
                z-index: -1;
            }

        .hero-content {
            position: relative;
            z-index: 2;
            text-align: center;
            padding: 0 20px;
        }

        .hero-title {
            font-family: 'Orbitron', monospace;
            font-weight: 900;
            font-size: 5rem;
            background: linear-gradient(90deg, var(--cynex-gold), var(--cynex-neon-blue), var(--cynex-gold));
            background-size: 300% 300%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-align: center;
            margin-bottom: 2rem;
            filter: drop-shadow(0 0 30px rgba(212, 175, 55, 0.8));
            animation: gradientShift 6s ease infinite;
            position: relative;
        }

        @@keyframes gradientShift {
            0% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }

            100% {
                background-position: 0% 50%;
            }
        }

        .hero-subtitle {
            font-size: 2rem;
            color: var(--cynex-silver);
            text-align: center;
            margin-bottom: 3rem;
            font-weight: 300;
            position: relative;
            display: inline-block;
            padding: 0 20px;
        }

            .hero-subtitle::after {
                content: '';
                position: absolute;
                bottom: -10px;
                left: 50%;
                transform: translateX(-50%);
                width: 100px;
                height: 3px;
                background: var(--cynex-gold-gradient);
            }

        /* Stats Cards */
        .stats-card {
            background: rgba(5, 15, 35, 0.9);
            border: 2px solid var(--cynex-gold);
            border-radius: 30px;
            padding: 2.5rem;
            text-align: center;
            position: relative;
            overflow: hidden;
            transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
        }

            .stats-card::before {
                content: '';
                position: absolute;
                top: -50%;
                left: -50%;
                width: 200%;
                height: 200%;
                background: radial-gradient(circle, rgba(212, 175, 55, 0.1) 0%, transparent 70%);
                animation: rotate 20s linear infinite;
                z-index: -1;
            }

        /* @@keyframes rotate {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        } */

        .stats-card::after {
            content: '';
            position: absolute;
            inset: 3px;
            background: rgba(5, 15, 35, 0.95);
            border-radius: 27px;
            z-index: -1;
        }

        .stats-card:hover {
            transform: scale(1.08) rotate(2deg);
            box-shadow: 0 20px 50px rgba(212, 175, 55, 0.5);
            border-color: var(--cynex-neon-blue);
        }

        .stats-number {
            font-family: 'Orbitron', monospace;
            font-size: 4rem;
            font-weight: 900;
            background: linear-gradient(90deg, var(--cynex-gold), var(--cynex-neon-blue));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 0.5rem;
            text-shadow: 0 0 20px rgba(212, 175, 55, 0.5);
        }

        .stats-label {
            color: var(--cynex-silver);
            font-size: 1.5rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            position: relative;
            display: inline-block;
        }

            .stats-label::after {
                content: '';
                position: absolute;
                bottom: -5px;
                left: 0;
                width: 0;
                height: 2px;
                background: var(--cynex-gold);
                transition: width 0.3s ease;
            }

        .stats-card:hover .stats-label::after {
            width: 100%;
        }

        /* Car Cards */
        .car-card {
            background: rgba(10, 15, 35, 0.9);
            border: 1px solid rgba(212, 175, 55, 0.2);
            border-radius: 30px;
            overflow: hidden;
            transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            position: relative;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
        }

            .car-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 5px;
                background: var(--cynex-gold-gradient);
                transform: scaleX(0);
                transition: transform 0.5s ease;
            }

            .car-card:hover {
                transform: translateY(-20px) scale(1.03);
                box-shadow: 0 30px 60px rgba(212, 175, 55, 0.4);
                border-color: var(--cynex-gold);
            }

                .car-card:hover::before {
                    transform: scaleX(1);
                }

        .car-image-container {
            position: relative;
            overflow: hidden;
            border-radius: 30px 30px 0 0;
        }

        .car-image {
            height: 300px;
            width: 100%;
            object-fit: cover;
            transition: all 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            transform: scale(1);
        }

        .car-card:hover .car-image {
            transform: scale(1.15);
            filter: brightness(1.1);
        }

        .car-image-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            padding: 20px;
            background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
            color: white;
            transform: translateY(50px);
            opacity: 0;
            transition: all 0.5s ease;
        }

        .car-card:hover .car-image-overlay {
            transform: translateY(0);
            opacity: 1;
        }

        .price-tag {
            background: var(--cynex-gold-gradient);
            color: var(--cynex-black);
            padding: 12px 30px;
            border-radius: 30px;
            font-weight: 800;
            font-size: 1.4rem;
            display: inline-block;
            box-shadow: 0 8px 25px rgba(212, 175, 55, 0.5);
            position: relative;
            overflow: hidden;
            margin: 20px 0;
            font-family: 'Orbitron', monospace;
            letter-spacing: 1px;
        }

            .price-tag::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, #F9E076, #D4AF37, #F9E076);
                transition: left 0.8s ease;
            }

            .price-tag:hover::before {
                left: 100%;
            }

        /* Form Controls */
        .form-control {
            background: rgba(5, 15, 35, 0.8);
            border: 2px solid rgba(212, 175, 55, 0.3);
            border-radius: 15px;
            color: var(--cynex-silver);
            padding: 18px 20px;
            font-size: 1.1rem;
            transition: all 0.4s ease;
            font-family: 'Rajdhani', sans-serif;
        }

            .form-control:focus {
                background: rgba(5, 15, 35, 0.9);
                border-color: var(--cynex-gold);
                box-shadow: 0 0 25px rgba(212, 175, 55, 0.4);
                color: white;
            }

            .form-control::placeholder {
                color: rgba(192, 192, 192, 0.6);
                font-family: 'Rajdhani', sans-serif;
            }

        .form-label {
            color: var(--cynex-gold);
            font-weight: 700;
            font-size: 1.2rem;
            margin-bottom: 12px;
            font-family: 'Orbitron', monospace;
            letter-spacing: 1px;
        }

        /* Tables */
        .table {
            background: rgba(5, 15, 35, 0.9);
            color: var(--cynex-silver);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6);
            border: 1px solid rgba(212, 175, 55, 0.2);
        }

            .table th {
                background: rgba(10, 36, 114, 0.9);
                color: var(--cynex-gold);
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 2px;
                border: none;
                padding: 25px;
                font-family: 'Orbitron', monospace;
            }

            .table td {
                border-color: rgba(212, 175, 55, 0.1);
                padding: 20px 25px;
                vertical-align: middle;
                font-size: 1.1rem;
            }

            .table tbody tr {
                transition: all 0.3s ease;
            }

                .table tbody tr:hover {
                    background: rgba(212, 175, 55, 0.05);
                    transform: scale(1.01);
                }

        /* Badges */
        .badge {
            font-size: 1rem;
            padding: 12px 25px;
            border-radius: 30px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-family: 'Orbitron', monospace;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
        }

            .badge.bg-success {
                background: linear-gradient(45deg, #00FF00, #00CC00) !important;
                border: 2px solid rgba(255, 255, 255, 0.2);
            }

            .badge.bg-danger {
                background: var(--cynex-gold-gradient) !important;
                border: 2px solid rgba(255, 255, 255, 0.2);
                color: var(--cynex-black) !important;
            }

        /* Alerts */
        .alert {
            border: none;
            border-radius: 20px;
            padding: 25px 30px;
            font-weight: 600;
            border-left: 5px solid;
            position: relative;
            overflow: hidden;
            animation: slideInRight 0.5s ease;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }

        /* @@keyframes slideInRight {
            from {
                transform: translateX(100%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        } */

        .alert::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 5px;
            height: 100%;
            background: var(--cynex-gold-gradient);
        }

        .alert-success {
            background: rgba(0, 255, 0, 0.1);
            color: #00FF00;
            border-left-color: #00FF00;
        }

        .alert-danger {
            background: rgba(212, 175, 55, 0.1);
            color: var(--cynex-gold);
            border-left-color: var(--cynex-gold);
        }

        /* Footer */
        .footer {
            background: rgba(5, 10, 20, 0.95);
            border-top: 3px solid var(--cynex-gold);
            color: var(--cynex-silver);
            padding: 5rem 0 3rem;
            margin-top: 5rem;
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(10px);
        }

            .footer::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: radial-gradient(circle at 30% 70%, rgba(212, 175, 55, 0.05) 0%, transparent 70%);
                z-index: 0;
            }

            .footer h5 {
                color: var(--cynex-gold);
                font-family: 'Orbitron', monospace;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 3px;
                margin-bottom: 2rem;
                position: relative;
                display: inline-block;
            }

                .footer h5::after {
                    content: '';
                    position: absolute;
                    bottom: -10px;
                    left: 0;
                    width: 50px;
                    height: 3px;
                    background: var(--cynex-gold);
                }

            .footer a {
                color: var(--cynex-silver);
                text-decoration: none;
                transition: all 0.3s ease;
                position: relative;
                display: inline-block;
                padding: 5px 0;
            }

                .footer a::after {
                    content: '';
                    position: absolute;
                    bottom: 0;
                    left: 0;
                    width: 0;
                    height: 2px;
                    background: var(--cynex-gold);
                    transition: width 0.3s ease;
                }

                .footer a:hover {
                    color: var(--cynex-gold);
                    transform: translateX(8px);
                }

                    .footer a:hover::after {
                        width: 100%;
                    }

        .social-links a {
            transition: all 0.3s ease;
            display: inline-block;
            padding: 10px;
            border-radius: 50%;
            background: rgba(212, 175, 55, 0.1);
            margin: 5px;
        }

            .social-links a:hover {
                transform: translateY(-5px) scale(1.2);
                background: var(--cynex-gold);
                color: var(--cynex-black);
                box-shadow: 0 10px 25px rgba(212, 175, 55, 0.4);
            }

        /* Animations */
        /* .animate-fade-in {
            opacity: 0;
            transform: translateY(50px);
            transition: all 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

            .animate-fade-in.visible {
                opacity: 1;
                transform: translateY(0);
            }

        .animate-slide-in {
            opacity: 0;
            transform: translateX(-100px);
            transition: all 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

            .animate-slide-in.visible {
                opacity: 1;
                transform: translateX(0);
            }

        .animate-scale-in {
            opacity: 0;
            transform: scale(0.8);
            transition: all 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

            .animate-scale-in.visible {
                opacity: 1;
                transform: scale(1);
            } */

        /* Loading Spinner */
        .loading-spinner {
            display: inline-block;
            width: 25px;
            height: 25px;
            border: 4px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: var(--cynex-gold);
            animation: spin 1s ease-in-out infinite;
        }

        /* @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        } */

        /* Scrollbar */
        ::-webkit-scrollbar {
            width: 15px;
        }

        ::-webkit-scrollbar-track {
            background: var(--cynex-black);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--cynex-gold-gradient);
            border-radius: 10px;
            border: 3px solid var(--cynex-black);
        }

            ::-webkit-scrollbar-thumb:hover {
                background: linear-gradient(45deg, #F9E076, #D4AF37);
            }

        /* Responsive Design */
        @@media (max-width: 992px) {
            .hero-title {
                font-size: 3.5rem;
            }

            .hero-subtitle {
                font-size: 1.5rem;
            }
        }

        @@media (max-width: 768px) {
            .hero-title {
                font-size: 2.8rem;
            }

            .hero-subtitle {
                font-size: 1.3rem;
            }

            .navbar-brand {
                font-size: 1.5rem;
            }

                .navbar-brand img {
                    height: 45px;
                }

            .stats-number {
                font-size: 3rem;
            }

            .btn-cynex-primary, .btn-cynex-secondary {
                padding: 12px 30px;
                font-size: 1rem;
            }
        }

        @@media (max-width: 576px) {
            .hero-title {
                font-size: 2.2rem;
            }

            .hero-subtitle {
                font-size: 1.1rem;
            }

            .navbar-brand {
                font-size: 1.3rem;
            }

            .stats-number {
                font-size: 2.5rem;
            }

            .stats-label {
                font-size: 1.2rem;
            }
        }

        /* Floating Elements
        .floating {
            animation: floating 3s ease-in-out infinite;
        } */

        @@keyframes floating {
            0% {
                transform: translateY(0px);
            }

            50% {
                transform: translateY(-15px);
            }

            100% {
                transform: translateY(0px);
            }
        }

        /* Glowing Effects */
        .glow-hover {
            transition: all 0.3s ease;
        }

            .glow-hover:hover {
                box-shadow: 0 0 30px rgba(212, 175, 55, 0.6);
            }

        /* Premium Section Divider */
        .section-divider {
            height: 4px;
            background: var(--cynex-gold-gradient);
            margin: 50px 0;
            border-radius: 2px;
            position: relative;
        }

            .section-divider::after {
                content: '';
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                width: 30px;
                height: 30px;
                background: var(--cynex-gold);
                border-radius: 50%;
                box-shadow: 0 0 20px rgba(212, 175, 55, 0.8);
            }
    </style>
</head>
