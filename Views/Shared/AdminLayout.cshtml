<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RentFlow - Admin Dashboard</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Custom CSS -->
    <link href="assets/css/admin-dashboard.css" rel="stylesheet">
</head>
<body class="bg-dark">
    <div class="d-flex vh-100">
        <!-- Sidebar -->
        <nav id="sidebar" class="sidebar bg-secondary">
            <!-- Header -->
            <div class="sidebar-header p-3 d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-2" id="logo-section">
                    <div class="logo-icon bg-danger rounded d-flex align-items-center justify-content-center">
                        <i class="bi bi-car-front text-white"></i>
                    </div>
                    <span class="fw-bold fs-5 text-white">RentFlow</span>
                </div>
                <button class="btn btn-sm btn-outline-secondary" id="sidebar-toggle">
                    <i class="bi bi-x"></i>
                </button>
            </div>

            <!-- Navigation -->
            <div class="sidebar-nav px-3 flex-grow-1">
                <div class="nav-item mb-1">
                    <button class="nav-link active" data-section="overview">
                        <i class="bi bi-bar-chart"></i>
                        <span class="nav-text">Dashboard</span>
                    </button>
                </div>
                <div class="nav-item mb-1">
                    <button class="nav-link" data-section="cars">
                        <i class="bi bi-car-front"></i>
                        <span class="nav-text">Fleet Management</span>
                    </button>
                </div>
                <div class="nav-item mb-1">
                    <button class="nav-link" data-section="customers">
                        <i class="bi bi-people"></i>
                        <span class="nav-text">Customers</span>
                    </button>
                </div>
                <div class="nav-item mb-1">
                    <button class="nav-link" data-section="bookings">
                        <i class="bi bi-calendar"></i>
                        <span class="nav-text">Reservations</span>
                    </button>
                </div>
                <div class="nav-item mb-1">
                    <button class="nav-link" data-section="revenue">
                        <i class="bi bi-currency-dollar"></i>
                        <span class="nav-text">Revenue</span>
                    </button>
                </div>
                <div class="nav-item mb-1">
                    <button class="nav-link" data-section="locations">
                        <i class="bi bi-geo-alt"></i>
                        <span class="nav-text">Locations</span>
                    </button>
                </div>
                <div class="nav-item mb-1">
                    <button class="nav-link" data-section="settings">
                        <i class="bi bi-gear"></i>
                        <span class="nav-text">Settings</span>
                    </button>
                </div>
            </div>

            <!-- Daily Inspiration Card -->
            <div class="p-3" id="inspiration-card">
                <div class="card bg-gradient text-white">
                    <div class="card-body p-3">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="bi bi-stars"></i>
                            <span class="fw-semibold">Daily Inspiration</span>
                        </div>
                        <p class="card-text small opacity-75 mb-2">Every rental is an opportunity to create memorable experiences.</p>
                        <div>⭐</div>
                    </div>
                </div>
            </div>
        </nav>

        <!-- Main Content -->
        <div class="flex-grow-1 d-flex flex-column">
            <!-- Header -->
            <header class="header bg-secondary border-bottom border-dark p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-3">
                        <div>
                            <h1 class="h3 fw-bold text-white mb-0 d-flex align-items-center gap-2">
                                Welcome back, Admin!
                                <span>👋</span>
                            </h1>
                            <p class="text-muted small mb-0" id="current-date"></p>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-3">
                        <!-- Font Size Controls -->
                        <div class="d-flex align-items-center gap-2 text-muted">
                            <span class="small">Font:</span>
                            <button class="btn btn-sm btn-outline-secondary font-btn" data-size="small">A</button>
                            <button class="btn btn-sm btn-outline-secondary font-btn active" data-size="medium">A</button>
                            <button class="btn btn-sm btn-outline-secondary font-btn" data-size="large">A</button>
                        </div>

                        <!-- Search -->
                        <div class="position-relative">
                            <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                            <input type="text" class="form-control bg-dark border-secondary text-white ps-5" placeholder="Search..." style="width: 250px;">
                        </div>

                        <!-- Notifications -->
                        <button class="btn btn-outline-secondary position-relative">
                            <i class="bi bi-bell"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">3</span>
                        </button>

                        <!-- Theme Toggle -->
                        <button class="btn btn-outline-secondary" id="theme-toggle">
                            <i class="bi bi-sun"></i>
                        </button>
                    </div>
                </div>
            </header>

            <!-- Main Content Area -->
            <main class="flex-grow-1 p-4 overflow-auto" id="main-content">
                <!-- Dashboard Overview (Default) -->
                <div id="overview-section" class="content-section">
                    <div class="row g-4 mb-4">
                        <!-- Stats Cards -->
                        <div class="col-md-3">
                            <div class="card bg-dark border-secondary">
                                <div class="card-body">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div>
                                            <p class="text-muted mb-1">Total Revenue</p>
                                            <h4 class="text-white mb-0">$124,500</h4>
                                            <small class="text-success">+12.5%</small>
                                        </div>
                                        <div class="text-danger">
                                            <i class="bi bi-currency-dollar fs-2"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-dark border-secondary">
                                <div class="card-body">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div>
                                            <p class="text-muted mb-1">Active Rentals</p>
                                            <h4 class="text-white mb-0">89</h4>
                                            <small class="text-success">+8.2%</small>
                                        </div>
                                        <div class="text-primary">
                                            <i class="bi bi-car-front fs-2"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-dark border-secondary">
                                <div class="card-body">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div>
                                            <p class="text-muted mb-1">Total Customers</p>
                                            <h4 class="text-white mb-0">2,847</h4>
                                            <small class="text-success">+15.3%</small>
                                        </div>
                                        <div class="text-warning">
                                            <i class="bi bi-people fs-2"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-dark border-secondary">
                                <div class="card-body">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div>
                                            <p class="text-muted mb-1">Fleet Utilization</p>
                                            <h4 class="text-white mb-0">78%</h4>
                                            <small class="text-success">+5.1%</small>
                                        </div>
                                        <div class="text-info">
                                            <i class="bi bi-graph-up fs-2"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-4">
                        <!-- Recent Rentals -->
                        <div class="col-md-8">
                            <div class="card bg-dark border-secondary">
                                <div class="card-header bg-transparent border-secondary">
                                    <h5 class="text-white mb-0">
                                        <i class="bi bi-clock me-2"></i>Recent Rentals
                                    </h5>
                                    <small class="text-muted">Latest rental activities</small>
                                </div>
                                <div class="card-body">
                                    <div class="d-flex align-items-center justify-content-between py-2 border-bottom border-secondary">
                                        <div>
                                            <div class="text-white fw-medium">John Smith</div>
                                            <div class="text-muted small">Tesla Model 3</div>
                                        </div>
                                        <div class="text-end">
                                            <span class="badge bg-success">Active</span>
                                            <div class="text-muted small">2 hours ago</div>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between py-2 border-bottom border-secondary">
                                        <div>
                                            <div class="text-white fw-medium">Sarah Johnson</div>
                                            <div class="text-muted small">BMW X5</div>
                                        </div>
                                        <div class="text-end">
                                            <span class="badge bg-primary">Completed</span>
                                            <div class="text-muted small">4 hours ago</div>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between py-2">
                                        <div>
                                            <div class="text-white fw-medium">Mike Wilson</div>
                                            <div class="text-muted small">Audi A4</div>
                                        </div>
                                        <div class="text-end">
                                            <span class="badge bg-warning">Pending</span>
                                            <div class="text-muted small">6 hours ago</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Fleet Performance -->
                        <div class="col-md-4">
                            <div class="card bg-dark border-secondary">
                                <div class="card-header bg-transparent border-secondary">
                                    <h5 class="text-white mb-0">
                                        <i class="bi bi-star me-2"></i>Fleet Performance
                                    </h5>
                                    <small class="text-muted">Vehicle status overview</small>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <div class="d-flex justify-content-between mb-1">
                                            <span class="text-white">Available</span>
                                            <span class="text-white">45 vehicles</span>
                                        </div>
                                        <div class="progress" style="height: 8px;">
                                            <div class="progress-bar bg-success" style="width: 70%"></div>
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <div class="d-flex justify-content-between mb-1">
                                            <span class="text-white">Rented</span>
                                            <span class="text-white">18 vehicles</span>
                                        </div>
                                        <div class="progress" style="height: 8px;">
                                            <div class="progress-bar bg-danger" style="width: 28%"></div>
                                        </div>
                                    </div>
                                    <div>
                                        <div class="d-flex justify-content-between mb-1">
                                            <span class="text-white">Maintenance</span>
                                            <span class="text-white">6 vehicles</span>
                                        </div>
                                        <div class="progress" style="height: 8px;">
                                            <div class="progress-bar bg-warning" style="width: 9%"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Other sections (hidden by default) -->
                <div id="cars-section" class="content-section d-none">
                    <h2 class="text-white mb-4">Fleet Management</h2>
                    <div class="card bg-dark border-secondary">
                        <div class="card-body">
                            <p class="text-white">Fleet Management - Coming Soon</p>
                        </div>
                    </div>
                </div>

                <div id="customers-section" class="content-section d-none">
                    <h2 class="text-white mb-4">Customer Management</h2>
                    <div class="card bg-dark border-secondary">
                        <div class="card-body">
                            <p class="text-white">Customer Management - Coming Soon</p>
                        </div>
                    </div>
                </div>

                <div id="bookings-section" class="content-section d-none">
                    <h2 class="text-white mb-4">Booking Management</h2>
                    <div class="card bg-dark border-secondary">
                        <div class="card-body">
                            <p class="text-white">Booking Management - Coming Soon</p>
                        </div>
                    </div>
                </div>

                <div id="revenue-section" class="content-section d-none">
                    <h2 class="text-white mb-4">Revenue Management</h2>
                    <div class="card bg-dark border-secondary">
                        <div class="card-body">
                            <p class="text-white">Revenue Management - Coming Soon</p>
                        </div>
                    </div>
                </div>

                <div id="locations-section" class="content-section d-none">
                    <h2 class="text-white mb-4">Locations Management</h2>
                    <div class="card bg-dark border-secondary">
                        <div class="card-body">
                            <p class="text-white">Locations Management - Coming Soon</p>
                        </div>
                    </div>
                </div>

                <div id="settings-section" class="content-section d-none">
                    <h2 class="text-white mb-4">Settings</h2>
                    <div class="card bg-dark border-secondary">
                        <div class="card-body">
                            <p class="text-white">Settings - Coming Soon</p>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Custom JS -->
    <script src="assets/js/admin-dashboard.js"></script>
</body>
</html>
