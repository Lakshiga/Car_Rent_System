@{
    ViewData["Title"] = "Booking Success";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="cynex-card p-5 text-center">
                <div class="mb-4">
                    <i class="fas fa-check-circle fa-5x text-success"></i>
                </div>
                <h2 class="cynex-font text-cynex-blue mb-3">BOOKING CONFIRMED!</h2>
                <p class="text-cynex-silver fs-5 mb-4">Thank you for choosing CYNEX BLAZER. Your luxury experience awaits.</p>

                <div class="alert alert-success">
                    <h5 class="mb-3">Booking Details</h5>
                    <p><strong>Booking ID:</strong> <span id="bookingId"></span></p>
                    <p><strong>Total Amount:</strong> <span id="totalAmount"></span></p>
                    <p><strong>Pickup Date:</strong> <span id="pickupDate"></span></p>
                    <p><strong>Return Date:</strong> <span id="returnDate"></span></p>
                </div>

                <div class="d-grid gap-3">
                    <a asp-action="BookingHistory" class="btn btn-cynex-primary">
                        <i class="fas fa-history"></i> VIEW BOOKING HISTORY
                    </a>
                    <a asp-action="BrowseCars" class="btn btn-cynex-secondary">
                        <i class="fas fa-car"></i> BROWSE MORE CARS
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>