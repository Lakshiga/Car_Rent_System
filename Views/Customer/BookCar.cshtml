@model Car_Rent_System.ViewModels.Booking.BookingViewModel

@{
    ViewData["Title"] = "Book Car";
    Layout = "_CustomerLayout";
    var car = ViewBag.Car as Car_Rent_System.Models.Car;
}

<div class="container">
    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h4 class="mb-0 fw-bold">
                        <i class="fas fa-calendar-plus"></i> Book Your Car
                    </h4>
                </div>
                <div class="card-body">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
                        </div>
                    }

                    <form asp-action="BookCar" method="post" enctype="multipart/form-data" onsubmit="return validateBookingDates()">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" id="DailyRate" value="@car?.DailyRate" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="PickupDate" class="form-label">
                                    <i class="fas fa-calendar-alt"></i> Pickup Date *
                                </label>
                                <input asp-for="PickupDate" type="date" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                                <span asp-validation-for="PickupDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="ReturnDate" class="form-label">
                                    <i class="fas fa-calendar-alt"></i> Return Date *
                                </label>
                                <input asp-for="ReturnDate" type="date" class="form-control" min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" required />
                                <span asp-validation-for="ReturnDate" class="text-danger"></span>
                            </div>
                        </div>


                        <!-- Customer Details Section -->
                        <div class="card bg-light mb-4">
                            <div class="card-header">
                                <h5 class="mb-0">
                                    <i class="fas fa-user"></i> Customer Details
                                </h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="LicenseNumber" class="form-label">
                                            <i class="fas fa-id-card"></i> License Number *
                                        </label>
                                        <input asp-for="LicenseNumber" class="form-control" placeholder="Enter your license number" required />
                                        <span asp-validation-for="LicenseNumber" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="NICNumber" class="form-label">
                                            <i class="fas fa-id-card"></i> NIC Number *
                                        </label>
                                        <input asp-for="NICNumber" class="form-control" placeholder="Enter your NIC number" required />
                                        <span asp-validation-for="NICNumber" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="licenseFrontFile" class="form-label">
                                            <i class="fas fa-id-card"></i> License Front Image *
                                        </label>
                                        <input type="file" id="licenseFrontFile" name="licenseFrontFile" class="form-control" accept="image/*" required />
                                        <small class="form-text text-muted">Upload front side of your driving license</small>
                                        <div id="licenseFrontPreview" class="mt-2" style="display: none;">
                                            <img id="licenseFrontImg" src="" alt="License Front Preview" class="img-thumbnail" style="max-width: 200px; max-height: 150px;">
                                        </div>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="licenseBackFile" class="form-label">
                                            <i class="fas fa-id-card"></i> License Back Image *
                                        </label>
                                        <input type="file" id="licenseBackFile" name="licenseBackFile" class="form-control" accept="image/*" required />
                                        <small class="form-text text-muted">Upload back side of your driving license</small>
                                        <div id="licenseBackPreview" class="mt-2" style="display: none;">
                                            <img id="licenseBackImg" src="" alt="License Back Preview" class="img-thumbnail" style="max-width: 200px; max-height: 150px;">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>


                        <div class="mb-3">
                            <label asp-for="SpecialRequirements" class="form-label">
                                <i class="fas fa-comment"></i> Special Requirements
                            </label>
                            <textarea asp-for="SpecialRequirements" class="form-control" rows="3" placeholder="Any special requests or requirements..."></textarea>
                        </div>

                        <!-- Booking Summary -->
                        <div class="card bg-light mb-4">
                            <div class="card-body">
                                <h5 class="card-title">Booking Summary</h5>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div id="dailyRateInfo">
                                            <p class="mb-1"><strong>Total Days:</strong> <span id="TotalDays">-</span></p>
                                            <p class="mb-1"><strong>Daily Rate:</strong> $@car?.DailyRate</p>
                                        </div>
                                        <div id="distanceInfo" style="display: none;">
                                            <p class="mb-1"><strong>Distance Traveled:</strong> <span id="DistanceTraveled">-</span> km</p>
                                            <p class="mb-1"><strong>Per KM Rate:</strong> $<span id="PerKmRate">@car?.PerKilometerRate?.ToString("0.00") ?? "2.50"</span></p>
                                        </div>
                                    </div>
                                    <div class="col-md-6 text-end">
                                        <h4 class="text-primary"><strong>Total Cost: <span id="TotalCost">$0.00</span></strong></h4>
                                        <div id="advancePaymentInfo" style="display: none;">
                                            <p class="mb-1"><strong>Advance Payment (50%):</strong> <span id="AdvancePayment">$0.00</span></p>
                                            <p class="mb-1"><strong>Remaining Amount:</strong> <span id="RemainingAmount">$0.00</span></p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="BrowseCars" class="btn btn-outline-secondary me-md-2">
                                <i class="fas fa-arrow-left"></i> Back to Cars
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-check"></i> Confirm Booking
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <!-- Car Details Card -->
            <div class="card sticky-top">
                <img src="~/images/Lambogini.jpg" class="car-image" alt="BMW M5 Competition"
                     class="card-img-top" style="height: 200px; object-fit: cover;" alt="@car?.CarName" />
                <div class="card-body">
                    <h5 class="card-title fw-bold">@car?.CarName</h5>
                    <p class="text-muted">@car?.CarModel | @car?.CarType</p>

                    @if (!string.IsNullOrEmpty(car?.Description))
                    {
                        <p class="card-text">@car.Description</p>
                    }

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <small class="text-muted">
                                <i class="fas fa-users"></i> @car?.SeatingCapacity Seats
                            </small>
                        </div>
                        <div class="col-6">
                            <small class="text-muted">
                                <i class="fas fa-gas-pump"></i> @car?.FuelType
                            </small>
                        </div>
                        <div class="col-6">
                            <small class="text-muted">
                                <i class="fas fa-cogs"></i> @car?.Transmission
                            </small>
                        </div>
                        @if (car?.Mileage != null)
                        {
                            <div class="col-6">
                                <small class="text-success">
                                    <i class="fas fa-leaf"></i> @car.Mileage km/l
                                </small>
                            </div>
                        }
                    </div>

                    <div class="text-center">
                        <span class="price-tag fs-4">$@car?.DailyRate/day</span>
                    </div>
                </div>
            </div>

            <!-- Terms and Conditions -->
            <div class="card mt-3">
                <div class="card-body">
                    <h6 class="card-title">
                        <i class="fas fa-info-circle"></i> Important Information
                    </h6>
                    <ul class="list-unstyled small">
                        <li><i class="fas fa-check text-success"></i> Valid driver's license required</li>
                        <li><i class="fas fa-check text-success"></i> Minimum age: 21 years</li>
                        <li><i class="fas fa-check text-success"></i> Full insurance coverage included</li>
                        <li><i class="fas fa-check text-success"></i> 24/7 roadside assistance</li>
                        <li><i class="fas fa-check text-success"></i> Free cancellation up to 24 hours</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function validateBookingDates() {
            var pickupDate = new Date($('#PickupDate').val());
            var returnDate = new Date($('#ReturnDate').val());
            var today = new Date();
            today.setHours(0, 0, 0, 0);

            if (pickupDate < today) {
                alert('Pickup date cannot be in the past.');
                return false;
            }

            if (returnDate <= pickupDate) {
                alert('Return date must be after pickup date.');
                return false;
            }

            return true;
        }

        function calculateTotalCost() {
            var pickupDate = new Date($('#PickupDate').val());
            var returnDate = new Date($('#ReturnDate').val());
            var dailyRate = parseFloat($('#DailyRate').val()) || 0;

            if (pickupDate && returnDate && returnDate > pickupDate) {
                // Calculate based on daily rate only
                var timeDiff = returnDate.getTime() - pickupDate.getTime();
                var daysDiff = Math.ceil(timeDiff / (1000 * 3600 * 24)) + 1;
                var totalCost = daysDiff * dailyRate;
                var advancePayment = totalCost * 0.5;
                var remainingAmount = totalCost - advancePayment;

                $('#TotalDays').text(daysDiff + ' day' + (daysDiff > 1 ? 's' : ''));
                $('#TotalCost').text('$' + totalCost.toFixed(2));
                $('#AdvancePayment').text('$' + advancePayment.toFixed(2));
                $('#RemainingAmount').text('$' + remainingAmount.toFixed(2));

                // Show daily rate info, hide distance info
                $('#dailyRateInfo').show();
                $('#distanceInfo').hide();
                $('#advancePaymentInfo').show();
            } else {
                $('#TotalDays').text('-');
                $('#TotalCost').text('$0.00');
                $('#AdvancePayment').text('$0.00');
                $('#RemainingAmount').text('$0.00');
                $('#advancePaymentInfo').hide();
            }
        }

        // Attach event listeners
        $('#PickupDate, #ReturnDate').on('change', calculateTotalCost);

        // Set return location same as pickup by default
        $('#PickupLocation').on('change', function () {
            if ($('#ReturnLocation').val() === '') {
                $('#ReturnLocation').val($(this).val());
            }
        });

        // Initialize calculation on page load
        $(document).ready(function () {
            calculateTotalCost();
        });

        // File preview functionality
        document.getElementById('licenseFrontFile').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('licenseFrontImg').src = e.target.result;
                    document.getElementById('licenseFrontPreview').style.display = 'block';
                };
                reader.readAsDataURL(file);
            } else {
                document.getElementById('licenseFrontPreview').style.display = 'none';
            }
        });

        document.getElementById('licenseBackFile').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('licenseBackImg').src = e.target.result;
                    document.getElementById('licenseBackPreview').style.display = 'block';
                };
                reader.readAsDataURL(file);
            } else {
                document.getElementById('licenseBackPreview').style.display = 'none';
            }
        });
    </script>
}
