@model IEnumerable<Car_Rent_System.Models.Car>

@{
    ViewData["Title"] = "Browse Cars";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="display-6 fw-bold">
                        <i class="fas fa-car"></i> Browse Our Fleet
                    </h1>
                    <p class="text-muted">Find the perfect car for your journey</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filter Section -->
    <div class="search-box">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Search Cars</label>
                <input type="text" name="searchTerm" class="form-control" placeholder="Car name or model..." value="@Context.Request.Query["searchTerm"]">
            </div>
            <div class="col-md-2">
                <label class="form-label">Car Type</label>
                <select name="carType" class="form-select">
                    <option value="">All Types</option>
                    @foreach (var type in ViewBag.CarTypes as List<string> ?? new List<string>())
                    {
                        <option value="@type" selected="@(Context.Request.Query["carType"] == type)">@type</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Fuel Type</label>
                <select name="fuelType" class="form-select">
                    <option value="">All Fuels</option>
                    @foreach (var fuel in ViewBag.FuelTypes as List<string> ?? new List<string>())
                    {
                        <option value="@fuel" selected="@(Context.Request.Query["fuelType"] == fuel)">@fuel</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Max Price/Day</label>
                <input type="number" name="maxPrice" class="form-control" placeholder="$100" value="@Context.Request.Query["maxPrice"]">
            </div>
            <div class="col-md-3">
                <label class="form-label">&nbsp;</label>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-fill">
                        <i class="fas fa-search"></i> Search
                    </button>
                    <a href="@Url.Action("BrowseCars")" class="btn btn-outline-secondary">
                        <i class="fas fa-redo"></i> Reset
                    </a>
                </div>
            </div>
        </form>
    </div>

    <!-- Cars Grid -->
    <div class="row g-4">
        @if (Model.Any())
        {
            @foreach (var car in Model)
            {
                <div class="col-xl-4 col-lg-6 col-md-6">
                    <div class="card car-card h-100">
                        <div class="position-relative">
                            <img src="~/images/Lambogini.jpg" class="car-image" alt="BMW M5 Competition"
                                 class="card-img-top car-image" alt="@car.CarName">
                            <div class="position-absolute top-0 end-0 m-3">
                                @if (car.IsAvailable)
                                {
                                    <span class="badge bg-success fs-6">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger fs-6">Booked</span>
                                }
                            </div>
                            <div class="position-absolute bottom-0 start-0 m-3">
                                <span class="price-tag fs-5">$@car.DailyRate/day</span>
                            </div>
                        </div>

                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title fw-bold mb-0">@car.CarName</h5>
                                <small class="text-muted">@car.CarModel</small>
                            </div>

                            <div class="row mb-3">
                                <div class="col-6">
                                    <small class="text-muted">
                                        <i class="fas fa-tag"></i> @car.CarType
                                    </small>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted">
                                        <i class="fas fa-gas-pump"></i> @car.FuelType
                                    </small>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-6">
                                    <small class="text-muted">
                                        <i class="fas fa-users"></i> @car.SeatingCapacity Seats
                                    </small>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted">
                                        <i class="fas fa-cogs"></i> @car.Transmission
                                    </small>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(car.Description))
                            {
                                <p class="card-text flex-grow-1 text-muted">@car.Description</p>
                            }

                            @if (car.Mileage.HasValue)
                            {
                                <div class="mb-3">
                                    <small class="text-success">
                                        <i class="fas fa-leaf"></i> @car.Mileage km/l
                                    </small>
                                </div>
                            }

                            <div class="mt-auto">
                                @if (car.IsAvailable)
                                {
                                    <div class="d-grid gap-2">
                                        <a asp-action="BookCar" asp-route-id="@car.CarID" class="btn btn-primary">
                                            <i class="fas fa-calendar-plus"></i> Book Now
                                        </a>
                                        <button class="btn btn-outline-info btn-sm" onclick="showCarDetails(@car.CarID)">
                                            <i class="fas fa-info-circle"></i> View Details
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-secondary w-100" disabled>
                                        <i class="fas fa-ban"></i> Currently Unavailable
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="text-center py-5">
                    <i class="fas fa-search fa-3x text-muted mb-3"></i>
                    <h4 class="text-muted">No cars found</h4>
                    <p class="text-muted">Try adjusting your search criteria</p>
                    <a href="@Url.Action("BrowseCars")" class="btn btn-primary">
                        <i class="fas fa-redo"></i> Reset Search
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<!-- Car Details Modal -->
<div class="modal fade" id="carDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Car Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="carDetailsContent">
                <!-- Car details will be loaded here -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showCarDetails(carId) {
            // This would typically make an AJAX call to get car details
            // For now, we'll show a placeholder
            $('#carDetailsContent').html(`
                <div class="text-center">
                    <i class="fas fa-spinner fa-spin fa-2x"></i>
                    <p class="mt-2">Loading car details...</p>
                </div>
            `);

            $('#carDetailsModal').modal('show');

            // Simulate loading delay
            setTimeout(function() {
                $('#carDetailsContent').html(`
                    <div class="row">
                        <div class="col-md-6">
                            <img src="/images/default-car.jpg" class="img-fluid rounded" alt="Car">
                        </div>
                        <div class="col-md-6">
                            <h4>Car Specifications</h4>
                            <ul class="list-unstyled">
                                <li><strong>Engine:</strong> 2.0L Turbo</li>
                                <li><strong>Horsepower:</strong> 250 HP</li>
                                <li><strong>Top Speed:</strong> 180 km/h</li>
                                <li><strong>Acceleration:</strong> 0-100 km/h in 7.2s</li>
                                <li><strong>Safety Rating:</strong> 5 Stars</li>
                            </ul>
                            <h5>Features</h5>
                            <ul>
                                <li>GPS Navigation</li>
                                <li>Bluetooth Connectivity</li>
                                <li>Backup Camera</li>
                                <li>Climate Control</li>
                                <li>Premium Sound System</li>
                            </ul>
                        </div>
                    </div>
                `);
            }, 1000);
        }
    </script>
}
