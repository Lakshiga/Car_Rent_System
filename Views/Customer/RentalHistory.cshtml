@using Car_Rent_System.Enums
@model IEnumerable<Car_Rent_System.ViewModels.Booking.BookingViewModel>
@{
    ViewData["Title"] = "Rental History";
    Layout = "_CustomerLayout";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="cynex-font text-cynex-silver">
                        <i class="fas fa-handshake text-cynex-red"></i> Rental History
                    </h1>
                    <p class="text-muted">View your completed rental transactions</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="cynex-card">
                <div class="card-header d-flex justify-content-between align-items-center" style="background: var(--cynex-red); color: white;">
                    <h5 class="mb-0 cynex-font">
                        <i class="fas fa-list"></i> Completed Rentals
                    </h5>
                    <span class="badge bg-light text-dark">@Model.Count() Total</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead style="background: rgba(255, 0, 0, 0.1);">
                                    <tr>
                                        <th>Car Details</th>
                                        <th>Pickup Date</th>
                                        <th>Return Date</th>
                                        <th>Duration</th>
                                        <th>Total Cost</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var booking in Model.Where(b => b.BookingStatus == BookingStatus.Rented || b.BookingStatus == BookingStatus.Completed))
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <img src="@booking.Car?.ImageUrl" class="rounded me-3" style="width: 50px; height: 50px; object-fit: cover;" alt="Car">
                                                    <div>
                                                        <div class="fw-bold text-cynex-silver">@booking.Car?.CarName</div>
                                                        <small class="text-muted">@booking.Car?.CarModel</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-cynex-silver">@booking.PickupDate.ToString("MMM dd, yyyy")</td>
                                            <td class="text-cynex-silver">@booking.ReturnDate.ToString("MMM dd, yyyy")</td>
                                            <td class="text-cynex-silver">
                                                @{
                                                    var duration = (booking.ReturnDate - booking.PickupDate).Days + 1;
                                                }
                                                @duration day@(duration > 1 ? "s" : "")
                                            </td>
                                            <td class="fw-bold text-cynex-red">$@booking.TotalCost.ToString("F2")</td>
                                            <td>
                                                <span class="badge bg-@(booking.BookingStatus == BookingStatus.Completed ? "success" : "info")">
                                                    @booking.BookingStatus
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-handshake fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">No rental history</h5>
                            <p class="text-muted">Your completed rentals will appear here.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
