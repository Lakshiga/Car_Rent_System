@{
    ViewData["Title"] = "Login";
}

<div class="min-vh-100 d-flex align-items-center" style="background: var(--cynex-gradient); padding-top: 100px;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="cynex-card p-5">
                    <div class="text-center mb-5">
                        <img src="~/images/Cynex Blazer.png" alt="CYNEX BLAZER" style="height: 80px; margin-bottom: 2rem; filter:  drop-shadow(0 0 50px rgba(10, 36, 114, 0.8));">
                        <h2 class="cynex-font text-cynex-silver mb-3">WELCOME BACK</h2>
                        <p class="text-muted">Access your elite account</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-triangle"></i> @ViewBag.Error
                        </div>
                    }

                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success">
                            <i class="fas fa-check-circle"></i> @ViewBag.Success
                        </div>
                    }

                    <form method="post" onsubmit="return validateLogin()">
                        <div class="mb-4">
                            <label for="username" class="form-label">
                                <i class="fas fa-user text-cynex-red"></i> Username
                            </label>
                            <input type="text" class="form-control" id="username" name="username" required
                                   placeholder="Enter your username">
                        </div>

                        <div class="mb-4">
                            <label for="password" class="form-label">
                                <i class="fas fa-lock text-cynex-red"></i> Password
                            </label>
                            <input type="password" class="form-control" id="password" name="password" required
                                   placeholder="Enter your password">
                        </div>

                        <div class="mb-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="rememberMe">
                                <label class="form-check-label text-cynex-silver" for="rememberMe">
                                    Remember me
                                </label>
                            </div>
                        </div>

                        <div class="d-grid mb-4">
                            <button type="submit" class="btn btn-cynex-primary btn-lg">
                                <i class="fas fa-sign-in-alt"></i> ACCESS ACCOUNT
                            </button>
                        </div>
                    </form>

                    <div class="text-center">
                        <p class="text-muted mb-3">Don't have an elite account?</p>
                        <a asp-action="Register" class="btn btn-cynex-secondary">
                            <i class="fas fa-crown"></i> JOIN THE ELITE
                        </a>
                    </div>

                    <div class="text-center mt-4">
                        <a href="#" class="text-cynex-red text-decoration-none">
                            <i class="fas fa-key"></i> Forgot Password?
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        document.getElementById("login-form").addEventListener("submit", async (e) => {
            e.preventDefault();

            const username = document.getElementById("username").value.trim();
            const password = document.getElementById("password").value.trim();
            if (!username || !password) {
                return showAlert("Please enter both username and password.", "danger");
            }

            try {
                const response = await fetch("/api/accountapi/login", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ username, password })
                });

                console.log("Status:", response.status, response.statusText);
                const text = await response.text(); // Always read text first

                if (response.ok) {
                    const data = text ? JSON.parse(text) : {};
                    console.log("Response JSON:", data);
                    localStorage.setItem('jwtToken', data.token);
                    localStorage.setItem('userRole', data.role);
                    console.log('Before redirect: token=', localStorage.getItem('jwtToken'));

                    showAlert("Login successful! Redirecting...", "success");

                    await fetch('/Account/LoginSessionSet', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ username, password })
                    });
                    setTimeout(() => {
                        const role = data.role;
                        window.location.href = role === "Admin" ? "/Admin/Dashboard"
                                            : role === "Customer" ? "/Customer/Dashboard"
                                            : role === "Staff" ? "/Staff/Dashboard"
                                            : "/";
                    }, 1000);
                } else {
                    console.error("Response text:", text);
                    const data = text ? JSON.parse(text) : {};
                    showAlert(data.error || "Invalid credentials.", "danger");
                }
            } catch (error) {
                console.error("Login error:", error);
                showAlert("An unexpected error occurred.", "danger");
            }
        });

        function showAlert(msg, type) {
            const c = document.getElementById("login-alert");
            c.innerHTML = `<div class="alert alert-${type} mt-2"><i class="fas fa-info-circle"></i> ${msg}</div>`;
            setTimeout(() => c.innerHTML = "", 5000);
        }
    </script>
}