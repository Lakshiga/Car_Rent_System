@model IEnumerable<Car_Rent_System.Models.ApplicationUser>
@{
    ViewData["Title"] = "Manage Users";
    Layout = "_AdminLayout";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <h1 class="cynex-font text-cynex-silver display-5 mb-4">
                <i class="fas fa-users text-cynex-red"></i> MANAGE USERS
            </h1>
            <p class="text-muted mb-5">View and manage all approved users</p>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="cynex-card">
                <div class="card-header d-flex justify-content-between align-items-center" style="background: var(--cynex-red); color: white;">
                    <h5 class="mb-0 cynex-font">APPROVED USERS</h5>
                    <a asp-action="PendingUsers" class="btn btn-sm btn-light">
                        View Pending <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
                <div class="card-body p-0">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead style="background: rgba(255, 0, 0, 0.1);">
                                    <tr>
                                        <th>User</th>
                                        <th>Email</th>
                                        <th>Phone</th>
                                        <th>Role</th>
                                        <th>Registration Date</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in Model)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="bg-cynex-red rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                                        <i class="fas fa-user text-white"></i>
                                                    </div>
                                                    <div>
                                                        <div class="fw-bold text-cynex-silver">@user.FullName</div>
                                                        <small class="text-muted">@user.UserName</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-cynex-silver">@user.Email</td>
                                            <td class="text-cynex-silver">@user.PhoneNumber</td>
                                            <td>
                                                @switch (user.Role)
                                                {
                                                    case Car_Rent_System.Enums.Role.Admin:
                                                        <span class="badge bg-danger">@user.Role</span>
                                                        break;
                                                    case Car_Rent_System.Enums.Role.SubAdmin:
                                                        <span class="badge bg-warning">@user.Role</span>
                                                        break;
                                                    case Car_Rent_System.Enums.Role.Staff:
                                                        <span class="badge bg-info">@user.Role</span>
                                                        break;
                                                    case Car_Rent_System.Enums.Role.Customer:
                                                        <span class="badge bg-primary">@user.Role</span>
                                                        break;
                                                    case Car_Rent_System.Enums.Role.Driver:
                                                        <span class="badge bg-success">@user.Role</span>
                                                        break;
                                                    case Car_Rent_System.Enums.Role.VehicleOwner:
                                                        <span class="badge bg-secondary">@user.Role</span>
                                                        break;
                                                }
                                            </td>
                                            <td class="text-cynex-silver">@user.JoinDate.ToString("MMM dd, yyyy")</td>
                                            <td>
                                                @if (user.VerificationStatus == Car_Rent_System.Enums.VerificationStatus.Approved)
                                                {
                                                    <span class="badge bg-success">Approved</span>
                                                }
                                                else if (user.VerificationStatus == Car_Rent_System.Enums.VerificationStatus.Rejected)
                                                {
                                                    <span class="badge bg-danger">Rejected</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning">Pending</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <button class="btn btn-sm btn-outline-info" title="Edit User">
                                                        <i class="fas fa-edit"></i>
                                                    </button>
                                                    @if (user.Role != Car_Rent_System.Enums.Role.Admin)
                                                    {
                                                        <form method="post" asp-action="DeleteUser" asp-route-id="@user.Id"
                                                              onsubmit="return confirm('Are you sure you want to delete this user?');">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete User">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        </form>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-users fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">No users found</h5>
                            <p class="text-muted">Users will appear here once they are approved.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>