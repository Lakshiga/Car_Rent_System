@{
    ViewData["Title"] = "Booking Confirmed";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body text-center py-5">
                    <div class="mb-4">
                        <i class="fas fa-check-circle text-success" style="font-size: 4rem;"></i>
                    </div>
                    
                    <h2 class="text-success mb-3">Booking Successfully Confirmed!</h2>
                    
                    <p class="lead mb-4">@ViewBag.Message</p>
                    
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle"></i>
                        <strong>What happens next?</strong>
                        <ul class="list-unstyled mt-2">
                            <li>✓ Your booking request has been submitted</li>
                            <li>✓ Our admin team will review your documents</li>
                            <li>✓ You'll receive an email notification once approved</li>
                            <li>✓ You can track your booking status in your dashboard</li>
                        </ul>
                    </div>
                    
                    <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                        <a asp-controller="Customer" asp-action="Dashboard" class="btn btn-primary btn-lg me-md-2">
                            <i class="fas fa-tachometer-alt"></i> Go to Dashboard
                        </a>
                        <a asp-controller="Customer" asp-action="BrowseCars" class="btn btn-outline-secondary btn-lg">
                            <i class="fas fa-car"></i> Browse More Cars
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
