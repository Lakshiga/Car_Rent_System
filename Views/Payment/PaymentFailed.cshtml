@{
    ViewData["Title"] = "Payment Failed";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body text-center py-5">
                    <div class="mb-4">
                        <i class="fas fa-times-circle text-danger" style="font-size: 4rem;"></i>
                    </div>
                    
                    <h2 class="text-danger mb-3">Payment Failed</h2>
                    
                    <p class="lead mb-4">@ViewBag.Message</p>
                    
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle"></i>
                        <strong>Don't worry!</strong> Your booking was not processed. You can try again or contact our support team for assistance.
                    </div>
                    
                    <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                        <a asp-controller="Customer" asp-action="BrowseCars" class="btn btn-primary btn-lg me-md-2">
                            <i class="fas fa-redo"></i> Try Again
                        </a>
                        <a asp-controller="Home" asp-action="Contact" class="btn btn-outline-secondary btn-lg">
                            <i class="fas fa-phone"></i> Contact Support
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
