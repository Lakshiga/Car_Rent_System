@model IEnumerable<Car_Rent_System.Models.Car>

@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="container hero-content">
        <div class="row align-items-center min-vh-100">
            <div class="col-lg-6 ">
                <h1 class="hero-title">
                    LUXURY<br>
                    <span class="text-cynex-blue">REDEFINED</span>
                </h1>
                <p class="hero-subtitle">
                    Experience the pinnacle of automotive excellence with CYNEX BLAZER's premium fleet.
                    Where every journey becomes a statement of power, prestige, and unparalleled performance.
                </p>
                <div class="d-flex flex-column flex-md-row gap-3">
                    <a asp-controller="Customer" asp-action="BrowseCars" class="btn btn-cynex-primary btn-lg">
                        <i class="fas fa-fire"></i> EXPLORE FLEET
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-cynex-secondary btn-lg">
                        <i class="fas fa-crown"></i> JOIN ELITE
                    </a>
                </div>
            </div>
            <div class="col-lg-6 text-center ">
                <div class="position-relative">
                    <img src="~/images/Cynex Blazer.png" alt="CYNEX BLAZER" class="img-fluid" style="max-height: 400px; filter: drop-shadow(0 0 50px rgba(10, 36, 114, 0.8));">
                    <div class="position-absolute top-0 start-0 w-100 h-100" style="background: radial-gradient(circle, transparent 40%, rgba(10, 36, 114, 0.1) 70%);"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Statistics Section <div class="col-lg-3 col-md-6">
    <div class="cynex-card p-4 text-center h-100">
-->
<section class="py-5" style="background: rgba(0, 0, 0, 0.9);">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="stats-card ">
                    <div class="stats-number">@ViewBag.TotalCars</div>
                    <div class="stats-label">Premium Vehicles</div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="stats-card ">
                    <div class="stats-number">@ViewBag.AvailableCars</div>
                    <div class="stats-label">Ready to Drive</div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="stats-card ">
                    <div class="stats-number">@ViewBag.TotalBookings</div>
                    <div class="stats-label">Elite Clients</div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="stats-card ">
                    <div class="stats-number">24/7</div>
                    <div class="stats-label">Concierge Service</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Fleet Section -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="cynex-font" style="font-size: 3rem; color: var(--cynex-silver); margin-bottom: 1rem;">
                ELITE <span class="text-cynex-blue">COLLECTION</span>
            </h2>
            <p class="lead text-cynex-silver">Handpicked supercars and luxury vehicles for the discerning driver</p>
            <div style="width: 100px; height: 3px; background: var(--cynex-blue-gradient); margin: 2rem auto;"></div>
        </div>

        <div class="row g-4">
            @foreach (var car in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="car-card cynex-card ">
                        <div class="position-relative overflow-hidden">
                            @* <img src="@(string.IsNullOrEmpty(car.ImageUrl)
                                                     ? Url.Content("~/images/BMW.jpg")
                                                     : Url.Content(car.ImageUrl.StartsWith("~/images/Lambogini.jpg") ? car.ImageUrl : "~/images/Mercedes.jpg" + car.ImageUrl))"
                             class="car-image" alt="@car.CarName"> *@
                            <img src="~/images/blue-lamborghini.jpg" class="car-image" alt="BMW M5 Competition">
                            <div class="position-absolute top-0 end-0 m-3">
                                @if (car.IsAvailable)
                                {
                                    <span class="badge bg-success fs-6">
                                        <i class="fas fa-check-circle"></i> AVAILABLE
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger fs-6">
                                        <i class="fas fa-lock"></i> RESERVED
                                    </span>
                                }
                            </div>
                            <div class="position-absolute bottom-0 start-0 m-3">
                                <span class="price-tag">$@car.DailyRate<small>/day</small></span>
                            </div>
                        </div>

                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="card-title cynex-font text-cynex-silver mb-0">@car.CarName</h5>
                                <small class="text-cynex-blue fw-bold">@car.CarModel</small>
                            </div>

                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <small class="text-muted">
                                        <i class="fas fa-tag text-cynex-blue"></i> @car.CarType
                                    </small>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted">
                                        <i class="fas fa-gas-pump text-cynex-blue"></i> @car.FuelType
                                    </small>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted">
                                        <i class="fas fa-users text-cynex-blue"></i> @car.SeatingCapacity Seats
                                    </small>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted">
                                        <i class="fas fa-cogs text-cynex-blue"></i> @car.Transmission
                                    </small>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(car.Description))
                            {
                                <p class="card-text text-muted mb-4">@car.Description</p>
                            }

                            @if (car.IsAvailable)
                            {
                                <div class="d-grid">
                                    <a asp-controller="Customer" asp-action="BookCar" asp-route-id="@car.CarID"
                                       class="btn btn-cynex-primary">
                                        <i class="fas fa-fire"></i> RESERVE NOW
                                    </a>
                                </div>
                            }
                            else
                            {
                                <div class="d-grid">
                                    <button class="btn btn-outline-secondary" disabled>
                                        <i class="fas fa-lock"></i> CURRENTLY RESERVED
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="text-center mt-5">
            <a asp-controller="Customer" asp-action="BrowseCars" class="btn btn-cynex-secondary btn-lg">
                <i class="fas fa-eye"></i> VIEW COMPLETE FLEET
            </a>
        </div>
    </div>
</section>

